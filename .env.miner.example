# TuneForge Miner Configuration
# Copy to .env.miner and configure

# === Network ===
TF_NETUID=234
TF_SUBTENSOR_NETWORK=test
# TF_SUBTENSOR_CHAIN_ENDPOINT=wss://entrypoint-finney.opentensor.ai:443

# === Wallet ===
TF_WALLET_NAME=test-coldkey
TF_WALLET_HOTKEY=hotkey-miner
TF_WALLET_PATH=~/.bittensor/wallets

# === Neuron ===
TF_MODE=miner
TF_NEURON_EPOCH_LENGTH=100
TF_NEURON_TIMEOUT=120
TF_AXON_PORT=8091

# === Music Generation ===
# Default: MusicGen Large (baseline model, ~16GB VRAM)
TF_MODEL_NAME=facebook/musicgen-large
TF_GENERATION_MAX_DURATION=30
TF_GENERATION_SAMPLE_RATE=32000
#
# Alternative: Stable Audio Open 1.0 (~6GB VRAM, 44.1kHz stereo)
# Gated model — requires HuggingFace login: huggingface-cli login
# and accepting license at https://huggingface.co/stabilityai/stable-audio-open-1.0
# TF_MODEL_NAME=stable_audio
# TF_GENERATION_SAMPLE_RATE=44100
#
# Alternative: MusicGen Medium (~8GB VRAM, for lower-VRAM GPUs)
# TF_MODEL_NAME=facebook/musicgen-medium
# TF_GENERATION_SAMPLE_RATE=32000
#
# Alternative: ACE-Step 1.5 (requires separate repo clone, see docs/miner_setup.md)
# TF_MODEL_NAME=ace-step-1.5
# TF_GENERATION_SAMPLE_RATE=48000
#
# These are baseline starting models. Miners are encouraged to bring their own
# models and backends to compete for higher scores.
TF_GENERATION_TIMEOUT=120
TF_GPU_DEVICE=cuda:0
TF_MODEL_PRECISION=float16

# === API Server ===
TF_API_HOST=127.0.0.1
TF_API_PORT=8091
TF_API_MAX_QUEUE_SIZE=100
TF_API_RATE_LIMIT=10

# === Storage ===
TF_STORAGE_BACKEND=local
TF_STORAGE_PATH=./storage
# TF_S3_BUCKET=
# TF_S3_REGION=
# TF_S3_ACCESS_KEY=
# TF_S3_SECRET_KEY=

# === Database ===
TF_DB_URL=sqlite+aiosqlite:///./tuneforge.db

# === Logging ===
TF_LOG_LEVEL=INFO
TF_LOG_DIR=/tmp/tuneforge

# === Monitoring ===
TF_WANDB_ENABLED=false
# TF_WANDB_ENTITY=
TF_WANDB_PROJECT=tuneforge
