# TuneForge Miner Configuration
# Copy to .env.miner and configure

# === Network ===
TF_NETUID=234
TF_SUBTENSOR_NETWORK=test
# TF_SUBTENSOR_CHAIN_ENDPOINT=wss://test.finney.opentensor.ai:443

# === Wallet ===
TF_WALLET_NAME=default
TF_WALLET_HOTKEY=default
TF_WALLET_PATH=~/.bittensor/wallets

# === Neuron ===
TF_MODE=miner
TF_NEURON_EPOCH_LENGTH=100
TF_NEURON_TIMEOUT=120
TF_AXON_PORT=8091
#
# === Port Mapping (Docker / Vast.ai / NAT only) ===
# Skip this section if running on a VPS or bare-metal with direct public IP.
#
# When running inside a container or behind NAT, the port your process listens
# on (TF_AXON_PORT) differs from the port the outside world uses to reach you.
# Set these so the axon registers the PUBLIC address on-chain:
#
# TF_AXON_EXTERNAL_PORT=15822    # The public-facing port (e.g. Vast.ai mapped port)
# TF_AXON_EXTERNAL_IP=1.2.3.4   # Your public IP (Vast.ai instance IP, NAT gateway, etc.)

# === HuggingFace (required for gated models like Stable Audio) ===
# Get a token at https://huggingface.co/settings/tokens
# HF_TOKEN=hf_your_token_here

# === Music Generation ===
# Default: MusicGen Large (baseline model, ~16GB VRAM)
TF_MODEL_NAME=facebook/musicgen-large
TF_GENERATION_MAX_DURATION=30
TF_GENERATION_SAMPLE_RATE=32000
#
# Alternative: Stable Audio Open 1.0 (~6GB VRAM, 44.1kHz stereo)
# Gated model — requires:
#   1. Accept license at https://huggingface.co/stabilityai/stable-audio-open-1.0
#   2. Set HF_TOKEN above (or run: huggingface-cli login)
# TF_MODEL_NAME=stable_audio
# TF_GENERATION_SAMPLE_RATE=44100
#
# Alternative: MusicGen Medium (~8GB VRAM, for lower-VRAM GPUs)
# TF_MODEL_NAME=facebook/musicgen-medium
# TF_GENERATION_SAMPLE_RATE=32000
#
# Alternative: DiffRhythm v1.2 (~6-8GB VRAM, 44.1kHz stereo, 18x faster than MusicGen)
# Requires: git clone https://github.com/ASLP-lab/DiffRhythm ~/DiffRhythm
#           apt install espeak-ng
#           pip install -r ~/DiffRhythm/requirements.txt
# Base model (up to 95s):
# TF_MODEL_NAME=diffrhythm
# TF_GENERATION_SAMPLE_RATE=44100
# Full model (up to 285s / 4m45s):
# TF_MODEL_NAME=diffrhythm-full
# TF_GENERATION_SAMPLE_RATE=44100
#
# Alternative: HeartMuLa 3B (~8-10GB VRAM, 48kHz, vocals+lyrics, great prompt adherence)
# Requires: git clone https://github.com/HeartMuLa/heartlib && pip install -e heartlib
#           huggingface-cli download --local-dir ~/heartmula-ckpt HeartMuLa/HeartMuLaGen
# TF_MODEL_NAME=heartmula
# TF_GENERATION_SAMPLE_RATE=48000
# For 7B version (~16-20GB VRAM, higher quality):
# TF_MODEL_NAME=heartmula-7b
# TF_GENERATION_SAMPLE_RATE=48000
#
# These are baseline starting models. Miners are encouraged to bring their own
# models and backends to compete for higher scores.
TF_GENERATION_TIMEOUT=120
TF_GPU_DEVICE=cuda:0
TF_MODEL_PRECISION=float16

# === Logging ===
TF_LOG_LEVEL=INFO
TF_LOG_DIR=/tmp/tuneforge
