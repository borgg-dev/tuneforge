# TuneForge Validator Configuration
# Copy to .env.validator and configure

# === Network ===
TF_NETUID=0
TF_SUBTENSOR_NETWORK=finney
# TF_SUBTENSOR_CHAIN_ENDPOINT=wss://entrypoint-finney.opentensor.ai:443

# === Wallet ===
TF_WALLET_NAME=default
TF_WALLET_HOTKEY=default
TF_WALLET_PATH=~/.bittensor/wallets

# === Neuron ===
TF_MODE=validator
TF_NEURON_EPOCH_LENGTH=100
TF_NEURON_TIMEOUT=120
# TF_AXON_PORT=8092

# === Validation ===
TF_VALIDATION_INTERVAL=300
TF_CHALLENGE_BATCH_SIZE=8
TF_MAX_CONCURRENT_VALIDATIONS=4

# === Scoring Weights ===
TF_AUDIO_QUALITY_WEIGHT=0.3
TF_PROMPT_ADHERENCE_WEIGHT=0.4
TF_MUSICALITY_WEIGHT=0.2
TF_NOVELTY_WEIGHT=0.1

# === CLAP Model ===
TF_CLAP_MODEL_NAME=laion/larger_clap_music

# === Weight Setting ===
TF_WEIGHT_SETTER_STEP=175

# === Database ===
TF_DB_URL=sqlite+aiosqlite:///./tuneforge.db

# === Logging ===
TF_LOG_LEVEL=INFO
TF_LOG_DIR=/tmp/tuneforge

# === Monitoring ===
TF_WANDB_ENABLED=false
# TF_WANDB_ENTITY=
TF_WANDB_PROJECT=tuneforge
