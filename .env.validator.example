# TuneForge Validator Configuration
# Copy to .env.validator and configure

# === Network ===
TF_NETUID=234
TF_SUBTENSOR_NETWORK=test
# TF_SUBTENSOR_CHAIN_ENDPOINT=wss://entrypoint-finney.opentensor.ai:443

# === Wallet ===
TF_WALLET_NAME=default
TF_WALLET_HOTKEY=default
TF_WALLET_PATH=~/.bittensor/wallets

# === Neuron ===
TF_MODE=validator
TF_NEURON_EPOCH_LENGTH=100
TF_NEURON_TIMEOUT=120
TF_AXON_PORT=8092

# === Validation ===
TF_VALIDATION_INTERVAL=300
TF_CHALLENGE_BATCH_SIZE=8
TF_MAX_CONCURRENT_VALIDATIONS=4

# === Scoring Weights (must sum to 1.0) ===
# TF_WEIGHT_CLAP=0.30
# TF_WEIGHT_QUALITY=0.06
# TF_WEIGHT_MUSICALITY=0.10
# TF_WEIGHT_PRODUCTION=0.08
# TF_WEIGHT_MELODY=0.07
# TF_WEIGHT_NEURAL_QUALITY=0.10
# TF_WEIGHT_PREFERENCE=0.06
# TF_WEIGHT_STRUCTURAL=0.07
# TF_WEIGHT_VOCAL=0.06
# TF_WEIGHT_DIVERSITY=0.05
# TF_WEIGHT_SPEED=0.05
# TF_WEIGHT_ATTRIBUTE=0.00

# === CLAP Model ===
TF_CLAP_MODEL_NAME=laion/larger_clap_music

# === AcoustID ===
# TF_ACOUSTID_API_KEY=

# === Organic API (runs inside the validator) ===
TF_ORGANIC_API_ENABLED=true
TF_ORGANIC_API_PORT=8090

# === Weight Setting ===
TF_WEIGHT_SETTER_STEP=115

# === Database ===
TF_DB_URL=sqlite+aiosqlite:///./tuneforge.db

# === Logging ===
TF_LOG_LEVEL=INFO
TF_LOG_DIR=/tmp/tuneforge

# === Monitoring ===
TF_WANDB_ENABLED=false
# TF_WANDB_ENTITY=
TF_WANDB_PROJECT=tuneforge
