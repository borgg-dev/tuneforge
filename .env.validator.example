# TuneForge Validator Configuration
# Copy to .env.validator and configure

# === Network ===
TF_NETUID=234
TF_SUBTENSOR_NETWORK=test
# TF_SUBTENSOR_CHAIN_ENDPOINT=wss://test.finney.opentensor.ai:443

# === Wallet ===
TF_WALLET_NAME=default
TF_WALLET_HOTKEY=default
TF_WALLET_PATH=~/.bittensor/wallets

# === Neuron ===
TF_MODE=validator
TF_NEURON_EPOCH_LENGTH=100
TF_NEURON_TIMEOUT=120
TF_AXON_PORT=8092
#
# === Port Mapping (Docker / Vast.ai / NAT only) ===
# Skip this section if running on a VPS or bare-metal with direct public IP.
#
# When running inside a container or behind NAT, the port your process listens
# on (TF_AXON_PORT) differs from the port the outside world uses to reach you.
# Set these so the axon registers the PUBLIC address on-chain:
#
# TF_AXON_EXTERNAL_PORT=15941    # The public-facing port (e.g. Vast.ai mapped port)
# TF_AXON_EXTERNAL_IP=1.2.3.4   # Your public IP (Vast.ai instance IP, NAT gateway, etc.)

# === Organic API (runs inside the validator) ===
TF_ORGANIC_API_ENABLED=true
TF_ORGANIC_API_PORT=8090

# === Platform API (push rounds/scores to TuneForge backend) ===
TF_VALIDATOR_API_URL=https://api.tuneforge.io
# TF_VALIDATOR_API_TOKEN=

# === Weight Setting ===
TF_WEIGHT_SETTER_STEP=115

# === AcoustID (optional — improves fingerprint penalty accuracy) ===
# TF_ACOUSTID_API_KEY=

# === Storage ===
TF_STORAGE_PATH=./storage

# === Logging ===
TF_LOG_LEVEL=INFO
TF_LOG_DIR=/tmp/tuneforge

# === W&B Monitoring ===
TF_WANDB_ENABLED=false
TF_WANDB_API_KEY=
